{
  "name": "mplayer",
  "version": "1.18.7",
  "description": "High-performance local music player with statistics – handles 10,000+ songs",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "prebuild:win": "node scripts/bump-version.js",
    "prebuild:mac": "node scripts/bump-version.js",
    "build:win": "npm run build && electron-builder --win --x64",
    "git-sync": "powershell ./scripts/sync-github.ps1",
    "build:mac": "npm run build && electron-builder --mac --universal"
  },
  "build": {
    "appId": "com.mplayer.app",
    "productName": "MPlayer",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.music"
    }
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "html-to-image": "^1.11.13",
    "music-metadata": "^7.14.0",
    "node-taglib-sharp": "^6.0.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tanstack/react-virtual": "^3.13.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^35.1.5",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "framer-motion": "^11.3.0",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "zustand": "^4.5.4"
  }
}
